# EeshaMart AI Space - Environment Variables
#
# Copy this file to `.env` for local development, OR set the same values as
# "Secrets" / "Variables" in your Hugging Face Space settings.
#
# On Hugging Face Spaces: Settings → Repository secrets → Add secret
# (Use "Secrets" for sensitive values like API keys; "Variables" for non-sensitive config.)
#
# On local dev:  cp .env.example .env  &&  fill in values, then run `python app.py`

# --- Required ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# --- Optional: Model selection (defaults shown) ---
# Chat model (Hugging Face model ID)
CHAT_MODEL_ID=Qwen/Qwen2.5-3B-Instruct
# Vision model for image understanding
VISION_MODEL_ID=Salesforce/blip-image-captioning-base

# --- Optional: Hugging Face token ---
# Only needed if you reference gated/private models. Public models work without it.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: Runtime tuning ---
PORT=7860
# Set to "float16" to halve memory (CPU-only torch may not support this; test first)
TORCH_DTYPE=float32
MAX_NEW_TOKENS=512
MAX_INPUT_TOKENS=3072
